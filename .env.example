# =============================================================================
# AI HR Platform — Frontend Environment Variables
# =============================================================================
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# cp .env.example .env
# =============================================================================

# ─── API Base URL ────────────────────────────────────────────────────────────
# عنوان الـ Backend API الذي تتصل به التطبيقات الأمامية
VITE_API_URL=http://localhost:4000

# ─── Landing Page URL (for logout redirects) ─────────────────────────────────
VITE_LANDING_PAGE_URL=http://localhost:5173

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development                         # development | production | test
